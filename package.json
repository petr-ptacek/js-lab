{
  "name": "@petr-ptacek/js-lab",
  "author": {
    "name": "Petr Ptáček",
    "email": "petr.ptacek99@gmail.com"
  },
  "description": "Place for developing and playing with JavaScript world.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "pnpm --parallel run test:js-core && pnpm run test:vue-core",
    "test:js-core": "pnpm --filter \"@petr-ptacek/js-core\" run test",
    "test:vue-core": "pnpm --filter \"@petr-ptacek/vue-core\" run test",
    "typecheck": "pnpm --parallel run typecheck:js-core && pnpm run typecheck:vue-core",
    "typecheck:js-core": "pnpm --filter \"@petr-ptacek/js-core\" run type:check",
    "typecheck:vue-core": "pnpm --filter \"@petr-ptacek/vue-core\" run type:check",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview",
    "docs:js-core": "pnpm --filter \"@petr-ptacek/js-core\" run docs:build",
    "dev": "pnpm --dir apps/playground/nuxt run dev",
    "prepare": "husky",
    "clean": "pnpm -r exec -- rm -rf node_modules & rm -rf node_modules",
    "commitlint": "commitlint",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format . --write"
  },
  "lint-staged": {
    "*.{js,ts,vue,json}": [
      "biome check --write"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/petr-ptacek/js-lab.git"
  },
  "bugs": {
    "url": "https://github.com/petr-ptacek/js-lab/issues"
  },
  "keywords": [
    "vue",
    "js",
    "vue3",
    "monorepo",
    "composables",
    "components",
    "ui",
    "utils",
    "playground"
  ],
  "license": "MIT",
  "homepage": "https://github.com/petr-ptacek/js-lab#readme",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tsconfig/node20": "^20.1.9",
    "@vitest/coverage-v8": "^4.1.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  }
}
